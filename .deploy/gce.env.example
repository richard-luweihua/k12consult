# Google Compute Engine 部署配置示例
# 复制为 .deploy/gce.env 后填写真实值

# SSH / 服务器
DEPLOY_HOST=YOUR_SERVER_IP
DEPLOY_USER=YOUR_SSH_USER
SSH_PORT=22
SSH_KEY_PATH=

# 代码与应用
REPO_URL=https://github.com/yourname/k12consult.git
BRANCH=main
DEPLOY_PATH=/var/www/k12consult
APP_NAME=k12consult
APP_PORT=3000
NODE_MAJOR=20

# 域名（可先留空，等域名解析完成后再补）
DOMAIN=
SERVER_NAMES=

# 站点地址
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 企业微信
WECOM_WEBHOOK_URL=
WECOM_HIGH_PRIORITY_WEBHOOK_URL=

# 后台登录 / 顾问注册
ADMIN_ACCESS_PASSWORD=
ADVISOR_INVITE_CODE=
